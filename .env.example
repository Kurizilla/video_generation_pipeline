# === video-pipeline — credenciales ===
# Copiá este archivo a `.env` (gitignored) y pegá los valores reales. NUNCA commitees `.env`.

# --- REQUERIDAS ---
# fal.ai — imagen (keyframes + edición) y video (shots image-to-video). Una sola key cubre todo.
FAL_KEY=

# ElevenLabs — voz en off (etapa de audio de la unificación). Header xi-api-key.
ELEVENLABS_API_KEY=

# --- CONFIG (no secretos; tienen default, override opcional) ---
# Candado de costo: el pipeline NO gasta a menos que esto sea "1" (default: dry-run sin gastar).
# Se puede setear por comando: LOOP_ALLOW_PAID=1 python -m pipeline.shots --project projects/example
# LOOP_ALLOW_PAID=1
# Resolución de los shots de video: 480p | 720p | 1080p | 4k (default 1080p).
# SHOT_RES=1080p

# --- LLM (opcional) — solo para "Distribuir con IA" en el PASO 2 de post-producción
#     (reparte un guion en prosa en una línea por toma). Sin credencial el botón queda bloqueado;
#     el resto del pipeline funciona igual.
#   Preferido: Vertex AI / Gemini con el login de gcloud (no requiere API key). Basta con estar
#   logueado (`gcloud auth login`) y tener proyecto (`gcloud config set project ...` o GCP_PROJECT).
#   Auto-detecta el Gemini más potente disponible (hoy gemini-2.5-pro); forzar con GEMINI_MODEL.
# GCP_PROJECT=
# GCP_REGION=us-central1
# GEMINI_MODEL=gemini-2.5-pro
#   Alternativas por API key (si no usás Vertex):
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_MODEL=
