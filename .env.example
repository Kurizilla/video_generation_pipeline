# === video-pipeline — credenciales ===
# Copiá este archivo a `.env` (gitignored) y pegá los valores reales. NUNCA commitees `.env`.

# --- REQUERIDAS ---
# fal.ai — imagen (keyframes + edición) y video (shots image-to-video). Una sola key cubre todo.
FAL_KEY=

# ElevenLabs — voz en off (etapa de audio de la unificación). Header xi-api-key.
ELEVENLABS_API_KEY=

# --- CONFIG (no secretos; tienen default, override opcional) ---
# Candado de costo: el pipeline NO gasta a menos que esto sea "1" (default: dry-run sin gastar).
# Se puede setear por comando: LOOP_ALLOW_PAID=1 python -m pipeline.shots --project projects/example
# LOOP_ALLOW_PAID=1
# Resolución de los shots de video: 480p | 720p | 1080p | 4k (default 1080p).
# SHOT_RES=1080p

# --- OPCIONALES (no usadas por el core actual; legacy / futuras integraciones) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GCP_PROJECT=
# GCP_REGION=us-central1
